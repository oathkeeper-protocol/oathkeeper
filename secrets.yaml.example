# CRE Secrets Mapping
# Copy to secrets.yaml — maps CRE secret names to environment variable names
# Actual values must be exported as env vars (e.g. export GROQ_API_KEY=gsk_...)
secretsNames:
  UPTIME_API_KEY:
    - UPTIME_API_KEY
  COMPLIANCE_API_KEY:
    - COMPLIANCE_API_KEY
  GROQ_API_KEY:
    - GROQ_API_KEY
